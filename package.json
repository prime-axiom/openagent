{
  "name": "openagent",
  "version": "0.10.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "node scripts/dev.mjs",
    "dev:all": "node scripts/dev.mjs",
    "dev:backend": "npm run dev --workspace=packages/web-backend",
    "dev:frontend": "npm run dev --workspace=packages/web-frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/",
    "lint:boundaries": "eslint -c eslint.boundaries.config.js \"packages/**/*.ts\"",
    "baseline:unit": "vitest run packages/core/src packages/telegram/src packages/web-frontend/app",
    "baseline:api": "vitest run packages/web-backend/src",
    "baseline:smoke": "vitest run packages/web-backend/src/app.test.ts --testNamePattern=\"health endpoint|auth flow|chat history API|settings API|providers API\"",
    "baseline:parity": "npm run lint:boundaries && npm run baseline:unit && npm run baseline:api && npm run baseline:smoke",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0"
  }
}
